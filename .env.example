# App
APP_NAME=MyL Advisor - AI Assistant
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# Database (shared with myl-database)
DATABASE_URL=postgresql://user:password@localhost:5432/myl_database

# Z.ai LLM configuration
ZAI_API_KEY=your_zai_api_key_here
ZAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZAI_MODEL=glm-4.7-flash

# Rate limiting (LLM calls)
LLM_RATE_LIMIT_SECONDS=2.0

# Cache TTL (24 hours)
CACHE_TTL_HOURS=24
